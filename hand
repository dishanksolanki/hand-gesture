<!-- ═══════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════ -->
<script>
// ─── Gesture definitions ──────────────────────────────────────
const GESTURES = {
  fist:       { e:'✊', n:'Closed Fist',   m:'Power!',          d:'All fingers curled inward. Strength or solidarity.' },
  open_palm:  { e:'✋', n:'Open Palm',     m:'Stop / Hello!',   d:'All five fingers extended and spread wide.' },
  thumb_up:   { e:'👍', n:'Thumbs Up',    m:'YES! / Great!',   d:'Thumb extended upward, all others curled.' },
  thumb_down: { e:'👎', n:'Thumbs Down',  m:'No / Dislike',    d:'Thumb pointing down, all others curled.' },
  victory:    { e:'✌️', n:'Victory',      m:'Peace! / Two!',   d:'Index and middle finger extended upward.' },
  point_up:   { e:'☝️', n:'Pointing Up',  m:'Look! / No.1!',   d:'Only index finger extended straight up.' },
  iloveyou:   { e:'🤟', n:'I Love You',   m:'Love! / Rock On', d:'Thumb, index, and pinky extended.' },
  rock:       { e:'🤘', n:'Rock On',      m:'Rock on!',        d:'Index and pinky extended, thumb out.' },
  none:       { e:'🖐️', n:'Detecting…',  m:'—',               d:'Keep your hand steady and well lit.' },
};

// ─── Geometric gesture classifier ────────────────────────────
// Uses MediaPipe's 21 hand landmarks to determine which fingers
// are extended, then maps combinations to gesture labels.

function dist3(a, b) {
  return Math.hypot(a.x - b.x, a.y - b.y, (a.z || 0) - (b.z || 0));
}

// True if finger tip is further from wrist than its PIP joint
function isExtended(lm, tip, pip) {
  return dist3(lm[0], lm[tip]) > dist3(lm[0], lm[pip]) * 1.05;
}

function classifyGesture(lm) {
  const idx   = isExtended(lm, 8,  6);
  const mid   = isExtended(lm, 12, 10);
  const ring  = isExtended(lm, 16, 14);
  const pinky = isExtended(lm, 20, 18);

  // Thumb: tip y above IP joint y (pointing up) or below (pointing down)
  // Also check horizontal extension for sideways thumb
  const thumbTipY = lm[4].y;
  const thumbIpY  = lm[3].y;
  const thumbMcpY = lm[2].y;
  const thumbUp   = thumbTipY < thumbIpY && thumbTipY < thumbMcpY;
  const thumbDown = thumbTipY > thumbIpY && thumbTipY > thumbMcpY;
  const thumbOut  = dist3(lm[4], lm[3]) > 0.07; // sideways extension

  // ── All fingers down → FIST
  if (!idx && !mid && !ring && !pinky && !thumbOut && !thumbUp && !thumbDown) {
    return { key: 'fist', conf: 0.91 };
  }

  // ── All four fingers up → OPEN PALM
  if (idx && mid && ring && pinky) {
    return { key: 'open_palm', conf: 0.93 };
  }

  // ── Only thumb up, no fingers
  if (!idx && !mid && !ring && !pinky && thumbUp) {
    return { key: 'thumb_up', conf: 0.89 };
  }

  // ── Only thumb down, no fingers
  if (!idx && !mid && !ring && !pinky && thumbDown) {
    return { key: 'thumb_down', conf: 0.87 };
  }

  // ── Index + middle, ring + pinky down → VICTORY / PEACE
  if (idx && mid && !ring && !pinky) {
    return { key: 'victory', conf: 0.89 };
  }

  // ── Only index → POINTING UP
  if (idx && !mid && !ring && !pinky) {
    return { key: 'point_up', conf: 0.88 };
  }

  // ── Thumb out + index + pinky → I LOVE YOU (ASL)
  if (thumbOut && idx && !mid && !ring && pinky) {
    return { key: 'iloveyou', conf: 0.86 };
  }

  // ── Index + pinky (no middle/ring) → ROCK ON
  if (idx && !mid && !ring && pinky) {
    return { key: 'rock', conf: 0.84 };
  }

  return { key: 'none', conf: 0.55 };
}

// ─── Drawing ──────────────────────────────────────────────────
const BONES = [
  [0,1],[1,2],[2,3],[3,4],
  [0,5],[5,6],[6,7],[7,8],
  [5,9],[9,10],[10,11],[11,12],
  [9,13],[13,14],[14,15],[15,16],
  [13,17],[17,18],[18,19],[19,20],[0,17]
];
const TIPS = new Set([4, 8, 12, 16, 20]);

function drawSkeleton(ctx, lm, W, H, boneColor) {
  const p = i => ({ x: lm[i].x * W, y: lm[i].y * H });
  ctx.strokeStyle = boneColor;
  ctx.lineWidth = 2;
  ctx.globalAlpha = 0.75;
  BONES.forEach(([a, b]) => {
    const pa = p(a), pb = p(b);
    ctx.beginPath(); ctx.moveTo(pa.x, pa.y); ctx.lineTo(pb.x, pb.y); ctx.stroke();
  });
  ctx.globalAlpha = 1;
  for (let i = 0; i < 21; i++) {
    const pt = p(i);
    ctx.beginPath();
    ctx.arc(pt.x, pt.y, TIPS.has(i) ? 5.5 : 3, 0, Math.PI * 2);
    ctx.fillStyle = TIPS.has(i) ? '#0dffb0' : '#ffffff';
    ctx.fill();
    ctx.strokeStyle = 'rgba(0,0,0,0.45)'; ctx.lineWidth = 1; ctx.stroke();
  }
}

function drawBox(ctx, lm, W, H, label, color) {
  const xs = lm.map(p => p.x * W), ys = lm.map(p => p.y * H);
  const pad = 20;
  const x1 = Math.min(...xs) - pad, y1 = Math.min(...ys) - pad;
  const x2 = Math.max(...xs) + pad, y2 = Math.max(...ys) + pad;

  ctx.strokeStyle = color; ctx.lineWidth = 1.5;
  ctx.setLineDash([6, 4]); ctx.strokeRect(x1, y1, x2-x1, y2-y1); ctx.setLineDash([]);

  const c = 13; ctx.lineWidth = 2.5;
  [[x1,y1,1,1],[x2,y1,-1,1],[x1,y2,1,-1],[x2,y2,-1,-1]].forEach(([cx,cy,dx,dy])=>{
    ctx.beginPath();
    ctx.moveTo(cx+dx*c,cy); ctx.lineTo(cx,cy); ctx.lineTo(cx,cy+dy*c);
    ctx.stroke();
  });

  ctx.font = 'bold 12px "DM Mono", monospace';
  const tw = ctx.measureText(label).width;
  ctx.fillStyle = 'rgba(0,0,0,0.85)';
  ctx.fillRect(x1-1, y1-27, tw+14, 22);
  ctx.fillStyle = color;
  ctx.fillText(label, x1+6, y1-10);
}

// ─── State ────────────────────────────────────────────────────
let handsModel = null, camera = null, stream = null;
let totalDetected = 0, lastKey = '', debounce = null;
let gestureLog = [];

const $ = id => document.getElementById(id);

function setLed(state) {
  $('led').className = 'led' + (state ? ' '+state : '');
  $('badge').className = 'hbadge' + (state === 'on' ? ' live-badge' : '');
  $('ledtxt').textContent = state === 'on' ? 'live' : state === 'busy' ? 'loading…' : 'offline';
}

function setDbg(msg, cls) {
  const el = $('dbg');
  el.textContent = msg;
  el.className = 'dbg' + (cls ? ' '+cls : '');
}

function updatePanel(key, conf) {
  const g   = GESTURES[key] || GESTURES.none;
  const pct = Math.round(conf * 100);
  const on  = key !== 'none';

  $('gE').textContent = g.e;
  $('gN').textContent = g.n;
  $('gM').textContent = g.m;
  $('gD').textContent = g.d;
  $('gcard').className = 'gcard' + (on ? ' lit' : '');

  $('pct').textContent = pct + '%';
  const fill = $('bar');
  fill.style.width = pct + '%';
  fill.style.background = pct > 78 ? '#0dffb0' : pct > 58 ? '#ffd166' : '#ff5e72';
  $('sC').textContent = on ? pct + '%' : '—';

  const pill = $('pill');
  if (on) { pill.textContent = g.e + '  ' + g.m; pill.classList.add('show'); }
  else      pill.classList.remove('show');
}

function resetPanel() {
  $('gE').textContent = '🖐️';
  $('gN').textContent = 'Waiting';
  $('gM').textContent = '—';
  $('gD').textContent = 'Show your hand clearly to the camera';
  $('gcard').className = 'gcard';
  $('pct').textContent = '0%';
  $('bar').style.width = '0%';
  $('sC').textContent = '—';
  $('pill').classList.remove('show');
  $('sH').textContent = '0';
}

function addLog(key, conf) {
  totalDetected++;
  $('sT').textContent = totalDetected;
  const g = GESTURES[key];
  const t = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  gestureLog.unshift({ g, conf: Math.round(conf*100), t });
  if (gestureLog.length > 60) gestureLog.pop();
  renderLog();
}

function renderLog() {
  const b = $('logBody');
  if (!gestureLog.length) { b.innerHTML = '<div class="empty">No gestures detected yet.</div>'; return; }
  b.innerHTML = gestureLog.map(h =>
    `<div class="log-row">
      <span class="log-name">${h.g.e}<span style="color:var(--txt)">${h.g.n}</span></span>
      <span class="log-meaning">${h.g.m}</span>
      <span class="log-time">${h.conf}% &middot; ${h.t}</span>
    </div>`
  ).join('');
}

window.clearLog = () => {
  gestureLog = []; totalDetected = 0; $('sT').textContent = 0; renderLog();
};

// ─── MediaPipe results callback ───────────────────────────────
function onResults(results) {
  const vid = $('vid');
  const cvs = $('cvs');
  const ctx = cvs.getContext('2d');

  cvs.width  = vid.videoWidth  || 640;
  cvs.height = vid.videoHeight || 480;
  ctx.clearRect(0, 0, cvs.width, cvs.height);

  const numHands = results.multiHandLandmarks ? results.multiHandLandmarks.length : 0;
  $('sH').textContent = numHands;

  if (numHands === 0) {
    resetPanel();
    setDbg('No hand detected — ensure good lighting and your full hand is visible in frame.');
    lastKey = '';
    return;
  }

  // Primary hand
  const lm = results.multiHandLandmarks[0];
  const { key, conf } = classifyGesture(lm);
  const color = key !== 'none' ? '#0dffb0' : '#4f8eff';
  const label = `${GESTURES[key].e} ${key !== 'none' ? GESTURES[key].m : 'Detecting…'} (${Math.round(conf*100)}%)`;

  drawBox(ctx, lm, cvs.width, cvs.height, label, color);
  drawSkeleton(ctx, lm, cvs.width, cvs.height, 'rgba(124,111,255,0.8)');

  // Secondary hand (just skeleton, different color)
  if (numHands > 1) {
    drawSkeleton(ctx, results.multiHandLandmarks[1], cvs.width, cvs.height, 'rgba(255,209,102,0.7)');
  }

  updatePanel(key, conf);
  setDbg(`Detected: ${key}  ·  confidence: ${Math.round(conf*100)}%  ·  hands in frame: ${numHands}`, key !== 'none' ? 'ok' : '');

  if (key !== 'none' && key !== lastKey) {
    lastKey = key;
    clearTimeout(debounce);
    debounce = setTimeout(() => addLog(key, conf), 400);
  } else if (key === 'none') {
    lastKey = '';
  }
}

// ─── Start ────────────────────────────────────────────────────
window.startCam = async function () {
  $('startBtn').disabled = true;
  setLed('busy');
  setDbg('Requesting camera access…');

  try {
    stream = await navigator.mediaDevices.getUserMedia({
      video: { width: { ideal: 640 }, height: { ideal: 480 }, facingMode: 'user' }
    });

    const vid = $('vid');
    vid.srcObject = stream;
    await vid.play();

    $('splash').classList.add('hidden');
    $('camFrame').classList.add('active');
    setDbg('Camera ready — loading MediaPipe Hands model…');

    handsModel = new Hands({
      locateFile: file => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`
    });

    handsModel.setOptions({
      maxNumHands:            2,
      modelComplexity:        1,   // 1 = full accuracy model
      minDetectionConfidence: 0.6,
      minTrackingConfidence:  0.5,
    });

    handsModel.onResults(onResults);

    camera = new Camera(vid, {
      onFrame: async () => { await handsModel.send({ image: vid }); },
      width: 640,
      height: 480,
    });

    await camera.start();

    setLed('on');
    setDbg('✅ Ready! Show your hand to the camera.', 'ok');
    $('stopBtn').disabled  = false;
    $('startBtn').disabled = false;

  } catch (err) {
    setLed('');
    $('splash').classList.remove('hidden');
    $('camFrame').classList.remove('active');
    $('startBtn').disabled = false;

    if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
      setDbg('❌ Camera permission denied. Allow camera access in your browser settings and try again.', 'err');
    } else if (err.name === 'NotFoundError') {
      setDbg('❌ No camera found. Please connect a webcam and try again.', 'err');
    } else if (err.message && (err.message.includes('fetch') || err.message.includes('load'))) {
      setDbg('❌ Could not load MediaPipe model. Check your internet connection and try again.', 'err');
    } else {
      setDbg('❌ Error: ' + err.message, 'err');
    }
    console.error('[GestureAI]', err);
  }
};

// ─── Stop ─────────────────────────────────────────────────────
window.stopCam = function () {
  if (camera)     { camera.stop(); camera = null; }
  if (handsModel) { handsModel.close(); handsModel = null; }
  if (stream)     { stream.getTracks().forEach(t => t.stop()); stream = null; }

  const vid = $('vid');
  vid.srcObject = null;
  const cvs = $('cvs');
  cvs.getContext('2d').clearRect(0, 0, cvs.width, cvs.height);

  setLed('');
  setDbg('Stopped.');
  resetPanel();
  $('stopBtn').disabled = true;
  $('splash').classList.remove('hidden');
  $('camFrame').classList.remove('active');
  lastKey = '';
};
</script>
</body>
</html>
