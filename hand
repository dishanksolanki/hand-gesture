<style>
/* ═══════════════════════════════════════════════
   RESET & VARIABLES
═══════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #08090d;
  --s1:      #0f1117;
  --s2:      #171921;
  --border:  rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.13);
  --acc:     #4f8eff;
  --grn:     #0dffb0;
  --ylw:     #ffd166;
  --red:     #ff5e72;
  --txt:     #eeeef5;
  --mut:     #55556e;
  --font:    'Cabinet Grotesk', sans-serif;
  --mono:    'DM Mono', monospace;
}

body {
  background: var(--bg);
  color: var(--txt);
  font-family: var(--font);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Subtle scanline texture */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg, transparent, transparent 2px,
    rgba(0,0,0,0.025) 2px, rgba(0,0,0,0.025) 4px
  );
  pointer-events: none;
  z-index: 999;
}

/* ═══════════════════════════════════════════════
   HEADER
═══════════════════════════════════════════════ */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 28px;
  background: var(--s1);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
  backdrop-filter: blur(12px);
}

.logo {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: -0.5px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.logo-dot { color: var(--acc); }

.hbadge {
  display: flex;
  align-items: center;
  gap: 7px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--mut);
  background: var(--s2);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 5px 13px;
  transition: border-color 0.3s;
}
.hbadge.live-badge { border-color: rgba(13,255,176,0.25); }

.led {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--mut);
  flex-shrink: 0;
  transition: background 0.3s, box-shadow 0.3s;
}
.led.on   { background: var(--grn); box-shadow: 0 0 8px var(--grn); }
.led.busy { background: var(--ylw); animation: blink 0.8s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.layout {
  display: grid;
  grid-template-columns: 1fr 350px;
  gap: 20px;
  max-width: 1180px;
  margin: 0 auto;
  padding: 24px 20px 40px;
}
@media(max-width: 820px) {
  .layout { grid-template-columns: 1fr; }
  .panel  { order: -1; }
}

/* ═══════════════════════════════════════════════
   CAMERA COLUMN
═══════════════════════════════════════════════ */
.cam-col { display: flex; flex-direction: column; gap: 12px; }

.cam-frame {
  position: relative;
  background: #000;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--border);
  aspect-ratio: 4/3;
  transition: border-color 0.3s;
}
.cam-frame.active { border-color: rgba(13,255,176,0.2); }

video {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transform: scaleX(-1);
}
canvas {
  position: absolute;
  inset: 0;
  width: 100%; height: 100%;
  transform: scaleX(-1);
}

/* Splash screen */
.splash {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14px;
  background: var(--s1);
  transition: opacity 0.4s, visibility 0.4s;
}
.splash.hidden { opacity: 0; visibility: hidden; }
.splash-icon { font-size: 56px; line-height: 1; }
.splash h2 { font-size: 18px; font-weight: 700; }
.splash p  { font-size: 13px; color: var(--mut); font-family: var(--mono); }

/* Gesture pill overlay */
.g-pill {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%) translateY(6px);
  background: rgba(0,0,0,0.84);
  border: 1.5px solid var(--grn);
  border-radius: 999px;
  padding: 7px 24px;
  font-weight: 700;
  font-size: 15px;
  color: var(--grn);
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.2s, transform 0.2s;
  pointer-events: none;
  backdrop-filter: blur(6px);
  letter-spacing: 0.3px;
}
.g-pill.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* Controls */
.ctrls { display: flex; gap: 10px; align-items: center; }

.btn {
  font-family: var(--font);
  font-size: 13px;
  font-weight: 700;
  padding: 10px 22px;
  border-radius: 11px;
  border: 1px solid var(--border2);
  cursor: pointer;
  background: var(--s1);
  color: var(--txt);
  transition: background 0.15s, border-color 0.15s, transform 0.1s;
  letter-spacing: 0.2px;
}
.btn:hover:not(:disabled) { background: var(--s2); border-color: rgba(255,255,255,0.2); }
.btn:active:not(:disabled){ transform: scale(0.97); }
.btn:disabled { opacity: 0.3; cursor: not-allowed; }
.btn.go   { background: var(--acc); border-color: var(--acc); color: #fff; }
.btn.go:hover:not(:disabled) { background: #6fa0ff; border-color: #6fa0ff; }
.btn.stop { color: var(--red); border-color: rgba(255,94,114,0.2); }
.btn.stop:hover:not(:disabled){ background: rgba(255,94,114,0.07); }

/* Debug bar */
.dbg {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--mut);
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 14px;
  min-height: 36px;
  line-height: 1.6;
  word-break: break-all;
}
.dbg.ok  { color: var(--grn); }
.dbg.err { color: var(--red); }

/* ═══════════════════════════════════════════════
   RIGHT PANEL
═══════════════════════════════════════════════ */
.panel { display: flex; flex-direction: column; gap: 12px; }

/* Gesture card */
.gcard {
  background: var(--s1);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 28px 22px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.gcard.lit {
  border-color: rgba(13,255,176,0.3);
  box-shadow: 0 0 40px rgba(13,255,176,0.05);
}
.gcard::before {
  content: '';
  position: absolute;
  top: -50px; left: 50%;
  transform: translateX(-50%);
  width: 240px; height: 120px;
  background: radial-gradient(ellipse, rgba(13,255,176,0.07) 0%, transparent 70%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.4s;
}
.gcard.lit::before { opacity: 1; }

.g-big  {
  font-size: 70px; line-height: 1;
  display: block; margin-bottom: 14px;
  transition: transform 0.25s;
}
.gcard.lit .g-big { transform: scale(1.1); }

.g-tag  {
  font-size: 10px; font-weight: 700;
  letter-spacing: 2.5px; text-transform: uppercase;
  color: var(--acc); margin-bottom: 6px;
}
.g-main {
  font-size: 23px; font-weight: 800;
  min-height: 34px; line-height: 1.2;
}
.g-desc {
  font-family: var(--mono); font-size: 11px;
  color: var(--mut); line-height: 1.65;
  min-height: 38px; margin-top: 8px;
}
.bar-row {
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 11px;
  color: var(--mut); margin: 14px 0 5px;
}
.bar-track {
  height: 3px; background: rgba(255,255,255,0.05);
  border-radius: 3px; overflow: hidden;
}
.bar-fill {
  height: 100%; border-radius: 3px;
  background: var(--grn);
  transition: width 0.18s, background 0.18s;
}
.mtag {
  display: inline-block; margin-top: 12px;
  background: rgba(79,142,255,0.08);
  border: 1px solid rgba(79,142,255,0.18);
  border-radius: 6px; padding: 3px 10px;
  font-family: var(--mono); font-size: 11px;
  color: var(--acc);
}

/* Stats */
.stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
.stat {
  background: var(--s1); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 8px; text-align: center;
}
.sv { font-family: var(--mono); font-size: 22px; font-weight: 500; color: var(--acc); display: block; }
.sk { font-size: 10px; color: var(--mut); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 3px; display: block; }

/* Guide */
.guide {
  background: var(--s1); border: 1px solid var(--border);
  border-radius: 14px; padding: 14px 14px;
}
.guide-title {
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px;
  color: var(--mut); margin-bottom: 10px;
}
.guide-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 6px; }
.gi {
  text-align: center; padding: 8px 4px 6px;
  border-radius: 8px; background: rgba(255,255,255,0.025);
  font-size: 10px; color: var(--mut); line-height: 1.5;
  cursor: default; transition: background 0.15s;
}
.gi:hover { background: rgba(255,255,255,0.05); }
.gi span  { font-size: 20px; display: block; margin-bottom: 2px; }

/* History log */
.log {
  background: var(--s1); border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden; flex: 1;
}
.log-hdr {
  display: flex; justify-content: space-between; align-items: center;
  padding: 10px 14px; border-bottom: 1px solid var(--border);
}
.log-hdr-title {
  font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--mut);
}
.log-clr {
  font-family: var(--mono); font-size: 11px;
  color: var(--mut); cursor: pointer; transition: color 0.15s;
}
.log-clr:hover { color: var(--txt); }
.log-body {
  max-height: 210px; overflow-y: auto;
  padding: 6px; display: flex; flex-direction: column; gap: 4px;
}
.log-body::-webkit-scrollbar { width: 3px; }
.log-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
.log-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 7px 10px; background: rgba(255,255,255,0.02);
  border-radius: 7px; font-size: 12px; gap: 6px;
  animation: fadein 0.18s ease;
}
@keyframes fadein { from{opacity:0;transform:translateY(-3px)} to{opacity:1;transform:none} }
.log-name    { display: flex; align-items: center; gap: 7px; }
.log-meaning { font-family: var(--mono); font-size: 11px; color: var(--grn); font-weight: 500; }
.log-time    { font-family: var(--mono); font-size: 10px; color: var(--mut); white-space: nowrap; }
.empty       { font-family: var(--mono); font-size: 12px; color: var(--mut); padding: 20px; text-align: center; }

/* Privacy notice */
.privacy {
  background: rgba(13,255,176,0.04);
  border: 1px solid rgba(13,255,176,0.1);
  border-radius: 12px;
  padding: 10px 14px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--mut);
  line-height: 1.6;
  display: flex;
  gap: 8px;
  align-items: flex-start;
}
.privacy-icon { font-size: 14px; flex-shrink: 0; margin-top: 1px; }

/* Footer */
footer {
  text-align: center;
  padding: 20px;
  font-family: var(--mono);
  font-size: 11px;
  color: var(--mut);
  border-top: 1px solid var(--border);
}
footer a { color: var(--acc); text-decoration: none; }
footer a:hover { text-decoration: underline; }
</style>
</head>
